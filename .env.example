# ========================
# HRMS Environment Config
# ========================

# --- General ---
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hrms
DB_USER=hrms_admin
DB_PASSWORD=hrms_secure_password_change_me
DATABASE_URL=postgresql://hrms_admin:hrms_secure_password_change_me@localhost:5432/hrms

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MinIO (S3-Compatible Storage) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=hrms_minio_access
MINIO_SECRET_KEY=hrms_minio_secret_change_me
MINIO_BUCKET=hrms-documents
MINIO_USE_SSL=false

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-refresh-secret-change-me-in-production
JWT_REFRESH_EXPIRES_IN=7d

# --- Encryption (AES-256-GCM) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# --- Email (SMTP) ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hrms.app

# --- Super Admin (Initial Setup) ---
SUPER_ADMIN_EMAIL=admin@hrms.app
SUPER_ADMIN_PASSWORD=Admin@123456

# --- Feature Flags ---
ENABLE_BIOMETRIC_POLLING=false
ENABLE_AI_TALENT=false
ENABLE_SAAS_MODE=false
